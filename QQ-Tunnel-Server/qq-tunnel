#!/bin/bash
#
# QQ-Tunnel Server CLI
# Usage: qq-tunnel {setup|start|stop|restart|status|logs|uninstall}
#

INSTALL_DIR="/opt/qq-tunnel"
SERVICE_NAME="qq-tunnel"
PYTHON_BIN="python3"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

check_root() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}Please run as root (sudo qq-tunnel ...)${NC}"
        exit 1
    fi
}

cmd_setup() {
    check_root
    $PYTHON_BIN "$INSTALL_DIR/setup.py"
}

cmd_start() {
    check_root
    if [ ! -f "$INSTALL_DIR/config.json" ]; then
        echo -e "${RED}No config.json found. Run 'qq-tunnel setup' first.${NC}"
        exit 1
    fi
    echo -e "${CYAN}Starting QQ-Tunnel...${NC}"
    systemctl start "$SERVICE_NAME"
    sleep 1
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo -e "${GREEN}QQ-Tunnel started successfully.${NC}"
    else
        echo -e "${RED}Failed to start. Check logs: qq-tunnel logs${NC}"
    fi
}

cmd_stop() {
    check_root
    echo -e "${CYAN}Stopping QQ-Tunnel...${NC}"
    systemctl stop "$SERVICE_NAME"
    echo -e "${GREEN}QQ-Tunnel stopped.${NC}"
}

cmd_restart() {
    check_root
    if [ ! -f "$INSTALL_DIR/config.json" ]; then
        echo -e "${RED}No config.json found. Run 'qq-tunnel setup' first.${NC}"
        exit 1
    fi
    echo -e "${CYAN}Restarting QQ-Tunnel...${NC}"
    systemctl restart "$SERVICE_NAME"
    sleep 1
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo -e "${GREEN}QQ-Tunnel restarted successfully.${NC}"
    else
        echo -e "${RED}Failed to restart. Check logs: qq-tunnel logs${NC}"
    fi
}

cmd_status() {
    echo -e "${CYAN}${BOLD}QQ-Tunnel Status${NC}"
    echo "----------------------------"
    if systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null; then
        echo -e "Service: ${GREEN}running${NC}"
    else
        echo -e "Service: ${RED}stopped${NC}"
    fi

    if [ -f "$INSTALL_DIR/config.json" ]; then
        echo -e "Config:  ${GREEN}found${NC}"
        DOMAIN=$(python3 -c "import json; c=json.load(open('$INSTALL_DIR/config.json')); print(c.get('recv_domain','N/A'))" 2>/dev/null)
        PORT=$(python3 -c "import json; c=json.load(open('$INSTALL_DIR/config.json')); print(c.get('receive_port','N/A'))" 2>/dev/null)
        BACKEND=$(python3 -c "import json; c=json.load(open('$INSTALL_DIR/config.json')); print(c.get('h_out_address','N/A') or 'dynamic')" 2>/dev/null)
        echo -e "Domain:  ${CYAN}${DOMAIN}${NC}"
        echo -e "Port:    ${CYAN}${PORT}${NC}"
        echo -e "Backend: ${CYAN}${BACKEND}${NC}"
    else
        echo -e "Config:  ${RED}not found${NC}"
    fi
}

cmd_logs() {
    journalctl -u "$SERVICE_NAME" -f --no-pager -n 50
}

cmd_uninstall() {
    check_root
    echo -e "${YELLOW}This will remove QQ-Tunnel and all its files.${NC}"
    read -p "Are you sure? (yes/no): " confirm
    if [ "$confirm" != "yes" ]; then
        echo "Cancelled."
        exit 0
    fi

    systemctl stop "$SERVICE_NAME" 2>/dev/null
    systemctl disable "$SERVICE_NAME" 2>/dev/null
    rm -f "/etc/systemd/system/${SERVICE_NAME}.service"
    systemctl daemon-reload
    rm -f "/usr/local/bin/qq-tunnel"
    rm -rf "$INSTALL_DIR"

    echo -e "${GREEN}QQ-Tunnel has been uninstalled.${NC}"
}

cmd_help() {
    echo -e "${BOLD}QQ-Tunnel Server${NC}"
    echo ""
    echo "Usage: qq-tunnel <command>"
    echo ""
    echo "Commands:"
    echo "  setup      Interactive configuration wizard"
    echo "  start      Start the tunnel service"
    echo "  stop       Stop the tunnel service"
    echo "  restart    Restart the tunnel service"
    echo "  status     Show tunnel status and config"
    echo "  logs       Follow live logs"
    echo "  uninstall  Remove QQ-Tunnel completely"
    echo ""
}

case "${1}" in
    setup)     cmd_setup ;;
    start)     cmd_start ;;
    stop)      cmd_stop ;;
    restart)   cmd_restart ;;
    status)    cmd_status ;;
    logs)      cmd_logs ;;
    uninstall) cmd_uninstall ;;
    *)         cmd_help ;;
esac
